# ===== Pickly — نموذج البيئة =====
# انسخه إلى .env — كل قيمة هنا تشغّل المشروع محلياً بالمحاكيات.
# القيم الإنتاجية تُدار في Secret Manager حصراً (docs/09§6) — راجع HUMAN-ACTIONS.md.

NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
WEB_BASE_URL=http://localhost:3000

# قاعدة البيانات (docker-compose)
DATABASE_URL=postgresql://pickly:pickly_local@localhost:5432/pickly

# Redis (BullMQ + realtime pubsub)
REDIS_URL=redis://localhost:6379

# JWT — جلسات قابلة للإلغاء (docs/11§0)
JWT_SECRET=dev-only-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ===== Adapters: mock يعمل الآن، production يُفعَّل بلصق المفاتيح =====

# SMS / OTP  (mock: الرمز يُطبع في اللوج ويُرسل إلى Mailhog)
SMS_PROVIDER=mock            # mock | unifonic | msegat
SMS_API_KEY=
SMS_SENDER_NAME=Pickly

# الدفع (mock: بوابة sandbox داخلية تحاكي Auth/Capture/Refund/Webhooks)
PAYMENT_PROVIDER=mock        # mock | hyperpay | moyasar | tap
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=dev-webhook-secret

# الخرائط وETA (mock: محاكي رحلة يتحرك على خط مستقيم بسرعة واقعية)
GEO_PROVIDER=mock            # mock | google
ROUTES_API_KEY=

# الإشعارات (mock: تُسجل في notification_deliveries وتُطبع في اللوج)
PUSH_PROVIDER=mock           # mock | fcm
FCM_SERVICE_ACCOUNT_JSON=

# Mailhog (قناة عرض رسائل OTP/البريد محلياً)
SMTP_HOST=localhost
SMTP_PORT=1025

# أعلام عامة
FEATURE_FLAGS_REFRESH_SECONDS=30
OTP_DEV_FIXED_CODE=            # اتركه فارغاً في أي بيئة غير التطوير
