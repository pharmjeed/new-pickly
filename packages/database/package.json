{
  "name": "@pickly/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src prisma/seed",
    "test": "echo \"database: tests run via api integration suites\"",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:reset": "prisma migrate reset --force",
    "seed": "tsx prisma/seed/index.ts",
    "studio": "prisma studio"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.0.1"
  },
  "devDependencies": {
    "@pickly/tsconfig": "workspace:*",
    "@pickly/eslint-config": "workspace:*",
    "@pickly/contracts": "workspace:*",
    "prisma": "^6.0.1",
    "typescript": "^5.6.3",
    "eslint": "^9.14.0",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  }
}
