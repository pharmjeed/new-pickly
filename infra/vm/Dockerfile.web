# صورة موحدة لتطبيقات Next.js — تُبنى بـ: --build-arg APP=customer-web PORT=3000
FROM node:22-alpine AS base
RUN corepack enable && corepack prepare pnpm@10.0.0 --activate
WORKDIR /repo

ARG APP
ARG PORT=3000

COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY packages ./packages
COPY apps/${APP} ./apps/${APP}
RUN pnpm install --frozen-lockfile --filter @pickly/${APP}...

# البروكسي الداخلي /api/* يقرأ API_INTERNAL_URL وقت التشغيل (next.config.mjs)
RUN pnpm --filter @pickly/${APP} build

ENV NODE_ENV=production
ENV PORT=${PORT}
ENV APP_NAME=@pickly/${APP}
EXPOSE ${PORT}
CMD pnpm --filter ${APP_NAME} start
