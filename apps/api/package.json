{
  "name": "@pickly/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:isolation": "vitest run --dir src --testNamePattern isolation"
  },
  "dependencies": {
    "@pickly/contracts": "workspace:*",
    "@pickly/database": "workspace:*",
    "@pickly/auth": "workspace:*",
    "@pickly/payments": "workspace:*",
    "@pickly/geo": "workspace:*",
    "@pickly/notifications": "workspace:*",
    "@pickly/observability": "workspace:*",
    "fastify": "^5.1.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/websocket": "^11.0.1",
    "ioredis": "^5.4.1",
    "zod": "^3.23.8",
    "dotenv": "^16.4.5",
    "pino-pretty": "^11.3.0"
  },
  "devDependencies": {
    "@pickly/tsconfig": "workspace:*",
    "@pickly/eslint-config": "workspace:*",
    "typescript": "^5.6.3",
    "eslint": "^9.14.0",
    "vitest": "^2.1.4",
    "tsx": "^4.19.2",
    "@types/node": "^22.9.0"
  }
}
